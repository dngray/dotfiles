# ~/.config/zathura/zathurarc

# Native status settings
set database            "sqlite"
set selection-clipboard "clipboard"
set statusbar-home-tilde true

# Complete Recipient Inversion
set recolor             "true"
set recolor-keep-hue    "true"

# Catppuccin Mocha Color Accents
set default-bg          "#1e1e2e"
set default-fg          "#cdd6f4"
set statusBar-bg        "#11111b"
set statusbar-fg        "#a6adc8"
set inputbar-bg         "#11111b"
set inputbar-fg         "#f5c2e7"

set recolor-lightcolor  "#1e1e2e"
set recolor-darkcolor   "#cdd6f4"
set highlight-color     "#f9e2af"
set highlight-active-color "#a6e3a1"

# Custom Keybindings
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map i recolor
map p print
