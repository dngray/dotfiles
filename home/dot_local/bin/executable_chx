#!/bin/sh

# Ensure the user provided exactly two arguments
if [ "$#" -ne 2 ]; then
  echo "Usage: $0 [--dupe | --recurse] <directory>"
  exit 1
fi

ACTION="$1"
TARGET_DIR="$2"

# Validate that the targeted directory actually exists
if [ ! -d "$TARGET_DIR" ]; then
  echo "Error: Directory '$TARGET_DIR' does not exist."
  exit 1
fi

case "$ACTION" in
--dupe)
  # Mimics your old md5Dupe, but safely locks to the top-level directory
  # (-maxdepth 1) and matches on the full 64-character SHA256 string (-w64).
  find "$TARGET_DIR" -maxdepth 1 -type f -print0 |
    xargs -0 sha256sum |
    sort |
    uniq -w64 --all-repeated=separate
  ;;

--recurse)
  # Mimics your old md5Recurse, but builds the file layout up to 10x faster
  # by streaming file streams in batches via xargs.
  OUT_NAME=$(basename "$(realpath "$TARGET_DIR")")
  OUTPUT_FILE="$(realpath "$TARGET_DIR")/${OUT_NAME}_manifest.txt"

  echo "Generating deep recursive SHA256 manifest..."
  find "$TARGET_DIR" -type f \( -not -name "${OUT_NAME}_manifest.txt" \) -print0 |
    xargs -0 sha256sum >"$OUTPUT_FILE"

  echo "Completed. Manifest cleanly saved to: $OUTPUT_FILE"
  ;;

*)
  echo "Invalid choice. Use --dupe or --recurse"
  exit 1
  ;;
esac
