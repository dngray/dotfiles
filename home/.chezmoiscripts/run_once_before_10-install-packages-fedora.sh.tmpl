{{- if (eq .chezmoi.osRelease.id "fedora") -}}
#!/bin/bash

set -eufo pipefail
{{ $ostreeOverlay := list
     "fish"
     "gvfs-mtp"
     "neovim"
     "udiskie" -}}

{{/* Lazyvim dependencies */}}
{{   $ostreeOverlay = concat $ostreeOverlay (list
       "gcc-c++") -}}

{{ if (and (eq .chezmoi.osRelease.name "fedora") (eq .chezmoi.osRelease.variant "Sway Atomic"))}}
{{   $ostreeOverlay = concat $ostreeOverlay (list
       "fish"
       "fzf"
       "gammastep"
       "gstreamer1-plugin-openh264"
       "gvfs-mtp"
       "gvfs-smb"
       "lxqt-policykit"
       "make"
       "mozilla-openh264"
       "neovim"
       "qemu"
       "starship"
       "swtpm"
       "syncthing"
       "tmux"
       "udiskie"
       "vault"
       "virt-install"
       "virt-manager"
       "wl-clipboard") -}}
{{- end }}

{{-    if (eq .chezmoi.osRelease.variant "Silverblue")  -}}
{{       $ostreeOverlay = concat $ostreeOverlay (list
         "dunst"
         "lxqt-policykit"
         "network-manager-applet"
         "python-i3ipc"
         "sway"
         "waybar" ) -}}
{{-    end }}

{{-    if (vault (printf "kv/users/%s/packages" .profiles.a)).data.data.rpmostree }}
{{-      range $ostreeOverlay }}
rpm-ostree install {{ . }}
{{-      end }}
{{-    end }}
{{- end }}
