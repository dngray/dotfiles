#!/bin/bash
set -eufo pipefail

{{- $pkgToggle := (vault (printf "kv/users/%s/packages" .profiles.a)).data.data -}}

{{- $plugins := dict
     "chezmoi" "https://github.com/joke/asdf-chezmoi.git"
     "rust" "https://github.com/asdf-community/asdf-rust.git"
-}}

{{- if .state.private }}
{{-   $plugins = dict
       "golang" "https://github.com/asdf-community/asdf-golang"
       "uv" "https://github.com/asdf-community/asdf-uv"
       "deno" "https://github.com/asdf-community/asdf-deno.git"

       | merge $plugins
-}}
{{- end }}

# Helper framework to safely register plugins without crashing on duplicates
safe_plugin_add() {
    local name="$1"
    local url="$2"

    if asdf plugin list 2>/dev/null | grep -Fqx "$name"; then
        echo "  Plugin '$name' already registered, skipping..."
    else
        echo "  Adding plugin '$name'..."
        if [ -n "$url" ]; then
            asdf plugin add "$name" "$url"
        else
            asdf plugin add "$name"
        fi
    fi
}

echo "Initializing asdf extension runtime lifecycle..."

# ==============================================================================
# PHASE 1: PLUGIN REGISTRATION
# ==============================================================================
{{- range $name, $url := $plugins }}
safe_plugin_add "{{ $name }}" "{{ $url }}"
{{- end }}

# ==============================================================================
# PHASE 2: VERSION BINDING
# ==============================================================================
{{- range $name, $_ := $plugins }}

{{- $runInstall := true -}}
{{- if eq $name "rust"   }}{{ $runInstall = $pkgToggle.rust_pkgs   }}{{ end -}}
{{- if eq $name "golang" }}{{ $runInstall = $pkgToggle.golang_pkgs }}{{ end -}}

{{- if $runInstall }}
echo "Provisioning standard environment matrix for: {{ $name }}"
asdf install "{{ $name }}" latest

# MODERN SPEC FIX: Swapped out legacy 'asdf global' with the unified 'asdf set' tool
# -u flag explicitly forces global/user-wide tool configuration mappings (~/.tool-versions)
asdf set -u "{{ $name }}" latest
{{- end }}

{{- end }}

echo "Runtime toolchain sync complete."
