# Modern, Hardened Global Defaults
Host *
  AddKeysToAgent yes
  ForwardAgent no
  ForwardX11 no
  ForwardX11Trusted no
  PasswordAuthentication no
  KbdInteractiveAuthentication no
  HostbasedAuthentication no
  PubkeyAuthentication yes
  GSSAPIAuthentication no
  GSSAPIDelegateCredentials no
  BatchMode no
  CheckHostIP yes
  AddressFamily any
  ConnectTimeout 0
  StrictHostKeyChecking ask
  UpdateHostKeys ask
  IdentitiesOnly yes
 
  # Cryptographic Hardening (Modern Elliptic Curves & Post-Quantum KEX)
  Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com
  MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
  KexAlgorithms sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org
  HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519,rsa-sha2-512-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256-cert-v01@openssh.com,rsa-sha2-256
 
  # Modernised Key Type Options (Supports Native + YubiKey FIDO2 tokens)
  PubkeyAcceptedAlgorithms sk-ssh-ed25519-cert-v01@openssh.com,sk-ssh-ed25519@openssh.com,ssh-ed25519-cert-v01@openssh.com,ssh-ed25519,rsa-sha2-512-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256-cert-v01@openssh.com,rsa-sha2-256

  # Session Handling & Environment Isolation
  EscapeChar ~
  Tunnel no
  TunnelDevice any:any
  PermitLocalCommand no
  VisualHostKey yes
  HashKnownHosts yes
  RekeyLimit 1G 1h
  UserKnownHostsFile ~/.ssh/known_hosts.d/%k
